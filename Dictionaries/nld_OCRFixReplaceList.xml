    <!-- ============================================================ -->
    <!-- CRITICAL DUTCH-SPECIFIC NOTES                                -->
    <!--                                                              -->
    <!-- 1. IJ DIGRAPH: Dutch treats IJ as a single unit. When a     -->
    <!--    word starting with ij is capitalised, BOTH letters        -->
    <!--    capitalise: IJsberg, IJmuiden, IJsselmeer.                -->
    <!--    OCR frequently splits or miscases this digraph.           -->
    <!--                                                              -->
    <!-- 2. TUSSENVOEGSEL (insertion): Dutch names contain lowercase  -->
    <!--    particles between first and last name:                    -->
    <!--    "van", "de", "den", "der", "van de", "van den", "van der" -->
    <!--    These are lowercase mid-name but capitalised when no      -->
    <!--    forename precedes: "Van Gogh" but "Vincent van Gogh".     -->
    <!--    Missing-space rules must not fire on these particles.     -->
    <!--                                                              -->
    <!-- 3. COMPOUND WORDS: Dutch compounds are written as one word   -->
    <!--    like German: ziekenhuis, voetbalveld, spoorwegstation.    -->
    <!--    Missing-space rules restricted to prepositions + Capital. -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- I / l CONFUSION FIXES (visual OCR errors, language-agnostic) -->
    <!-- ============================================================ -->

    <!-- [GEAR GRlNDER] â†’ [GEAR GRINDER] : lâ†’I inside all-caps brackets -->
    <RegEx find="\[([A-Z ]*)l([A-Z ]*)\]" spellCheck="[$1I$2]" replaceWith="[$1I$2]" />

    <!-- [ABC] bracket with l mixed into caps -->
    <RegEx find="\[([A-Zl]+)\]" replaceAllFrom="l" replaceAllTo="I" spellCheck="$1" replaceWith="[$1]" />

    <!-- SlNG â†’ SING : l inside all-caps word -->
    <RegEx find="\b([A-Z]+)l([A-Z]+)\b" spellCheck="$1I$2" replaceWith="$1I$2" />

    <!-- trailing l in all-caps word -->
    <RegEx find="\b([A-Z]+)l\b" spellCheck="$1I" replaceWith="$1I" />

    <!-- leading l before all-caps word -->
    <RegEx find="\bl([A-Z]+)\b" spellCheck="I$1" replaceWith="I$1" />

    <!-- chaIIenge â†’ challenge : IIâ†’ll mid lowercase word -->
    <RegEx find="\b([a-zĂ©Ă¨Ă«ĂŻĂłĂ¶ĂĽij]+)II([a-zĂ©Ă¨Ă«ĂŻĂłĂ¶ĂĽij]+)\b" spellCheck="$1ll$2" replaceWith="$1ll$2" />

    <!-- traIIer â†’ trailer : Iâ†’l mid lowercase word -->
