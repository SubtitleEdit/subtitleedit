    <!-- trailing Iâ†’l in capitalised word (e.g. AmsterdamI â†’ Amsterdaml) -->
    <RegEx find="\b([A-Z][a-zĂ©Ă¨Ă«ĂŻĂłĂ¶ĂĽij]+)I\b" spellCheck="$1l" replaceWith="$1l" />

    <!-- Iâ†’l mid capitalised word (e.g. AmstIerdam â†’ Amstlerdam) -->
